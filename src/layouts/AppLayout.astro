---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import Modal from '../components/Modal.astro';
import Drawer from '../components/Drawer.astro';
import NotificationsPopover from '../components/NotificationsPopover.astro';
import Toast from '../components/Toast.astro';
import { auth } from '../lib/auth';

const { title = 'Dashboard' } = Astro.props;
const session = await auth.api.getSession({
  headers: Astro.request.headers,
});
const userName = session?.user?.name ?? session?.user?.email ?? 'User';
const userEmail = session?.user?.email ?? '';
const role = String(session?.user?.role ?? 'employee');
const roleLabels: Record<string, string> = {
  admin: 'Administrator',
  asset_manager: 'Asset Manager',
  department_head: 'Department Head',
  employee: 'Employee',
};
const userRole = roleLabels[role] ?? 'Employee';
const activePath = Astro.url.pathname;

if (activePath === '/organization' && role !== 'admin') {
  return Astro.redirect('/');
}
---

<Layout>
  <div class="app" data-user-role={role}>
    <div class="mobile-overlay" id="overlay"></div>
    <aside class="sidebar" id="sidebar">
      <Sidebar userName={userName} userRole={userRole} role={role} userEmail={userEmail} activePath={activePath} />
    </aside>
    <main class="main">
      <header class="topbar">
        <Topbar title={title} />
      </header>
      <div class="content">
        <slot name="page" />
      </div>
    </main>
  </div>
  <Modal />
  <Drawer />
  <NotificationsPopover />
  <Toast />
  <script src="../scripts/app.js"></script>
</Layout>
