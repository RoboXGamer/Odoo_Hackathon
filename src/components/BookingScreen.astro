  <section class="screen active" data-title="Resource booking">
    <div class="page-head">
      <div>
        <div class="eyebrow">Shared resources</div>
        <h2>Resource booking</h2>
        <p>Find an open slot without double-booking rooms or equipment.</p>
      </div>
      <button class="btn primary" onclick="openModal('Book a resource')">＋ Book a slot</button>
    </div>
    <div class="panel">
      <div class="toolbar">
        <select class="btn" style="flex:1" id="bookingResource"></select>
        <input class="btn" id="bookingDay" type="date">
      </div>
      <div class="booking-day">
        <div class="times">
          <span>9:00</span><span>10:00</span><span>11:00</span><span>12:00</span><span>1:00</span><span>2:00</span>
        </div>
        <div class="timeline">
        </div>
      </div>
    </div>
  </section>




