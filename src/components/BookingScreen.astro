<template id="booking-template">
  <section class="screen" data-title="Resource booking">
    <div class="page-head">
      <div>
        <div class="eyebrow">Shared resources</div>
        <h2>Resource booking</h2>
        <p>Find an open slot without double-booking rooms or equipment.</p>
      </div>
      <button class="btn primary" onclick="openModal('Book a resource')">＋ Book a slot</button>
    </div>
    <div class="panel">
      <div class="toolbar">
        <select class="btn" style="flex:1"><option>Conference Room B2</option><option>Projector AF-0062</option></select>
        <button class="btn">‹ 7 Jul ›</button>
      </div>
      <div class="booking-day">
        <div class="times">
          <span>9:00</span><span>10:00</span><span>11:00</span><span>12:00</span><span>1:00</span><span>2:00</span>
        </div>
        <div class="timeline">
          <div class="booking one"><strong>Procurement team</strong><small>9:00–10:00 · 6 attendees</small></div>
          <div class="booking two"><strong>Requested slot conflicts</strong><small>10:30–11:45 · This time is unavailable</small></div>
        </div>
      </div>
    </div>
  </section>
</template>
