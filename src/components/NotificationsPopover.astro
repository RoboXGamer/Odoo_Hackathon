<div class="notification-popover" id="notificationsPopover" popover="auto">
  <div class="popover-head">
    <div>
      <h3>Notifications</h3>
      <small>Recent workspace activity</small>
    </div>
    <button class="action-btn" id="markNotificationsRead" type="button">Mark all read</button>
  </div>
  <div class="filters compact">
    <button class="tab active" data-notification-filter="All">All</button>
    <button class="tab" data-notification-filter="Alerts">Alerts</button>
    <button class="tab" data-notification-filter="Approvals">Approvals</button>
    <button class="tab" data-notification-filter="Bookings">Bookings</button>
  </div>
  <div id="notificationList"></div>
</div>
