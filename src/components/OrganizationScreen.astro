<template id="organization-template">
  <section class="screen" data-title="Organization setup">
    <div class="page-head">
      <div>
        <div class="eyebrow">Admin workspace</div>
        <h2>Organization setup</h2>
        <p>Manage departments, categories, and employees from one place.</p>
      </div>
      <button class="btn primary" onclick="openModal('Add department')">＋ Add department</button>
    </div>
    <div class="panel">
      <div class="tabs">
        <button class="tab active">Departments</button>
        <button class="tab">Categories</button>
        <button class="tab">Employees</button>
      </div>
      <div class="toolbar">
        <div class="search">
          <span style="position:absolute;left:13px;top:10px">⌕</span>
          <input placeholder="Search departments...">
        </div>
        <button class="btn">Filter</button>
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr><th>Department</th><th>Head</th><th>Parent department</th><th>Employees</th><th>Status</th><th></th></tr>
          </thead>
          <tbody>
            <tr><td><b>Engineering</b></td><td>Aditi Rao</td><td>—</td><td>42</td><td><span class="badge">Active</span></td><td>•••</td></tr>
            <tr><td><b>Facilities</b></td><td>Rohan Mehta</td><td>—</td><td>18</td><td><span class="badge">Active</span></td><td>•••</td></tr>
            <tr><td><b>Field Operations (East)</b></td><td>Sana Iqbal</td><td>Field Operations</td><td>26</td><td><span class="badge gray">Inactive</span></td><td>•••</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</template>
