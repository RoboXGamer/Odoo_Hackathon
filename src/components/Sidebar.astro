---
const { userName = 'User', userRole = 'Member', role = 'employee', userEmail = '', activePath = '/' } = Astro.props;
const initials = String(userName)
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
const links = [
  ['/', 'Dashboard', 'layout-dashboard', ['admin', 'asset_manager', 'department_head', 'employee']],
  ['/organization', 'Organization', 'building-2', ['admin']],
  ['/assets', 'Assets', 'boxes', ['admin', 'asset_manager', 'department_head', 'employee']],
  ['/allocation', 'Allocation', 'arrow-left-right', ['admin', 'asset_manager', 'department_head', 'employee']],
  ['/booking', 'Booking', 'calendar-days', ['admin', 'asset_manager', 'department_head', 'employee']],
  ['/maintenance', 'Maintenance', 'wrench', ['admin', 'asset_manager', 'department_head', 'employee']],
  ['/audit', 'Audit', 'clipboard-check', ['admin', 'asset_manager', 'department_head']],
  ['/reports', 'Reports', 'chart-column', ['admin', 'asset_manager', 'department_head']],
  ['/notifications', 'Notifications', 'bell', ['admin', 'asset_manager', 'department_head', 'employee']],
].filter(([, , , roles]) => roles.includes(role));
---

<div class="brand">
  <span class="brand-mark">A</span>AssetFlow
</div>
<div class="nav-label">Workspace</div>
<nav class="nav" id="nav">
  {links.map(([href, label, icon]) => (
    <a class:list={{ active: activePath === href }} href={href}>
      <i data-lucide={icon}></i>
      <span>{label}</span>
    </a>
  ))}
</nav>
<div class="sidebar-footer">
  <div class="user">
    <div class="avatar">{initials}</div>
    <div><b>{userName}</b><small>{userEmail || userRole}</small></div>
  </div>
</div>
