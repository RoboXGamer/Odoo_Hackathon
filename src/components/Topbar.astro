---
const { title = 'Dashboard' } = Astro.props;
---

<div style="display:flex;align-items:center;gap:12px">
  <button class="icon-btn menu-toggle" id="menuBtn" type="button" aria-label="Toggle sidebar" aria-expanded="true"><i data-lucide="menu"></i></button>
  <div class="top-title">
    <h1 id="topTitle">{title}</h1>
    <p>Central command for your organization's assets</p>
  </div>
</div>
<div class="top-actions">
  <button class="icon-btn" id="searchToggle" type="button" aria-label="Search"><i data-lucide="search"></i></button>
  <a class="icon-btn" href="/notifications" aria-label="Notifications"><i data-lucide="bell"></i><i class="dot"></i></a>
  <button class="btn primary" onclick="openModal('Register asset')"><i data-lucide="plus"></i><span>Add asset</span></button>
  <button class="btn" id="logoutBtn" type="button">Sign out</button>
</div>
